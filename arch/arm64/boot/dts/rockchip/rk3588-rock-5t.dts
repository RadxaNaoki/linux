/dts-v1/;

#include "rk3588-rock-5.dtsi"

/delete-node/ &leds;

/ {
	model = "Radxa ROCK 5T";
	compatible = "radxa,rock-5t", "rockchip,rk3588";

	analog-sound {
		hp-det-gpios = <&gpio4 RK_PC3 GPIO_ACTIVE_HIGH>;
	};

	leds: gpio-leds {
		compatible = "gpio-leds";

		led-0 {
			color = <LED_COLOR_ID_BLUE>;
			default-state = "on";
			function = LED_FUNCTION_STATUS;
			gpios = <&gpio0 RK_PA0 GPIO_ACTIVE_HIGH>;
			linux,default-trigger = "heartbeat";
		};
	};

	regulator-vcc3v3-wf {
		gpios = <&gpio2 RK_PC0 GPIO_ACTIVE_HIGH>;
	};

	regulator-vcc5v-usb {
		gpios = <&gpio1 RK_PA1 GPIO_ACTIVE_HIGH>;
	};

	regulator-vcc-5v {
		enable-active-high;
		gpios = <&gpio1 RK_PA0 GPIO_ACTIVE_HIGH>;
		pinctrl-names = "default";
		pinctrl-0 = <&hub_rst_1v8>;
	};

	rfkill {
		label = "rfkill-wlan";
		shutdown-gpios = <&gpio1 RK_PB0 GPIO_ACTIVE_HIGH>;
	};

	rfkill-bt {
		label = "rfkill-bt";
	};
};

&i2c1 {
	eeprom@50 {
		compatible = "belling,bl24c16a", "atmel,24c16";
		reg = <0x50>;
		pagesize = <16>;
		vcc-supply = <&vcc_3v3_s3>;
	};
};

&pcie2x1l1 {
	pinctrl-names = "default";
	pinctrl-0 = <&pcie30x1_1_perstn_m1>;
	reset-gpios = <&gpio4 RK_PA2 GPIO_ACTIVE_HIGH>;
	vpcie3v3-supply = <&vcc_3v3_s3>;
	status = "okay";
};

&pcie30phy {
	data-lanes = <1 1 2 2>;
};

&pcie3x2 {
	pinctrl-names = "default";
	pinctrl-0 = <&pcie30x2_perstn_m1>;
	reset-gpios = <&gpio4 RK_PB0 GPIO_ACTIVE_HIGH>;
	vpcie3v3-supply = <&vcc3v3_pcie30_1>;
	status = "okay";
};

&pcie3x4 {
	num-lanes = <2>;
};

&pinctrl {
	pcie2 {
		ekey_en: ekey-en {
			rockchip,pins = <2 RK_PC0 RK_FUNC_GPIO &pcfg_pull_none>;
		};

		pcie30x1_1_perstn_m1: pcie30x1-1-perstn-m1 {
			rockchip,pins = <4 RK_PA2 RK_FUNC_GPIO &pcfg_pull_none>;
		};
	};

	pcie3 {
		pcie30x2_perstn_m1: pcie30x4-perstn-m1 {
			rockchip,pins = <4 RK_PB0 RK_FUNC_GPIO &pcfg_pull_none>;
		};
	};

	sound {
		hp_detect: hp-detect {
			rockchip,pins = <4 RK_PC3 RK_FUNC_GPIO &pcfg_pull_none>;
		};
	};

	usb {
		hub_rst_1v8: hub-rst-1v8 {
			rockchip,pins = <1 RK_PA0 RK_FUNC_GPIO &pcfg_pull_none>;
		};

		usb_host_pwren_h: usb-host-pwren-h {
			rockchip,pins = <1 RK_PA1 RK_FUNC_GPIO &pcfg_pull_none>;
		};
	};
};

&pwm0 {
	status = "disabled";
};

&u2phy0_otg {
	phy-supply = <&vbus_typec0>;
};

&u2phy1_otg {
	/* connected to USB hub, which is powered by vcc_5v */
	phy-supply = <&vcc_5v>;
};

&u2phy2_host {
	/* connected to USB hub, which is powered by vcc_5v */
	phy-supply = <&vcc_5v>;
};

&usb_host2_xhci {
	status = "disabled";
};

&usbc0 {
	status = "okay";
};

&usbc0_con {
	power-role = "source";
	source-pdos =
		<PDO_FIXED(5000, 3000, PDO_FIXED_USB_COMM)>;
};

&usbdp_phy0 {
	sbu1-dc-gpios = <&gpio0 RK_PC4 GPIO_ACTIVE_HIGH>;
	sbu2-dc-gpios = <&gpio0 RK_PC5 GPIO_ACTIVE_HIGH>;
};
